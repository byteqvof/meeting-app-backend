# Supabase Edge Function secrets for local/reference use.
# Do not put real secrets in git.

# Development-only fake SMS sync. Keep false in production.
TOCH_ALLOW_DEV_PHONE_VERIFICATION=false

# Firebase Cloud Messaging. FCM_SERVICE_ACCOUNT_JSON is the full service
# account JSON stored as one Supabase secret value.
FCM_PROJECT_ID=
FCM_SERVICE_ACCOUNT_JSON=
